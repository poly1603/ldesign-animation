# Animation Package Environment Variables

# Development
NODE_ENV=development
VITE_DEV_PORT=5173

# API Configuration
VITE_API_BASE_URL=http://localhost:3000

# Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_PERFORMANCE_SAMPLE_RATE=0.1

# Animation Settings
VITE_DEFAULT_ANIMATION_DURATION=300
VITE_ENABLE_HARDWARE_ACCELERATION=true
VITE_MAX_CONCURRENT_ANIMATIONS=10

# Debug
VITE_DEBUG_ANIMATIONS=false
VITE_SHOW_PERFORMANCE_OVERLAY=false

# Build
VITE_BUILD_ANALYZE=false
VITE_BUILD_SOURCEMAP=true

# Testing
VITE_TEST_TIMEOUT=5000
VITE_TEST_COVERAGE=true